filter(date_time >= as.POSIXct("2024-10-01 11:32:59"))
ICU_PSY <- read_excel("C:/Users/Tanner/OneDrive - Michigan Technological University/PhD/HOBO/data/Mead/MEAD_DATA_MAY_2025_ON.xlsx",

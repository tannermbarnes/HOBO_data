)
# Parse the response
data_2024 <- fromJSON(content(response, "text"), flatten = TRUE)$results
temp_data_2024 <- as.data.frame(data_2024)
# View the first few rows of the dataset
head(temp_data_2024)
# Assuming `temp_data` is your data frame
temp_data_2024 <- temp_data_2024 %>%
mutate(date = as.Date(date),
temperature_c = value)
# Define freezing temperature threshold
freezing_temp <- 0
# Find the last spring freeze date
last_spring_freeze_2024 <- temp_data_2024 %>%
filter(temperature_c < freezing_temp, format(date, "%m") %in% c("03", "04", "05", "06")) %>%
summarize(last_spring = max(date, na.rm = TRUE)) %>%

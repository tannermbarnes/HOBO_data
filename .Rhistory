sheet = "gate_entrance") %>%
select(date, temp) %>%
mutate(
date_time = as.POSIXct(date, format ="Y-%m-%d %H:%M:%S"),
source = "Gate Entrance") %>%
filter(date_time >= as.POSIXct("2024-10-01 11:32:59"))

# Load dplyr for data manipulation
library(dplyr)
# Combine all datasets into one
all_data <- bind_rows(temp_data_2014, temp_data_2015, temp_data_2016, temp_data_2017,
temp_data_2018, temp_data_2019, temp_data_2020, temp_data_2021,
temp_data_2022, temp_data_2023, temp_data_2024)
# Convert date column to Date type if it's not already
all_data <- all_data %>%
mutate(date = as.Date(date),
temperature_c = value)
# Define freezing temperature threshold
freezing_temp <- 0
# Extract year for each date to enable grouping
all_data <- all_data %>%
mutate(year = format(date, "%Y"))
# Identify last spring freeze and first fall freeze for each year
freeze_dates <- all_data %>%
group_by(year) %>%
summarize(
last_spring_freeze = max(date[temperature_c < freezing_temp & format(date, "%m") %in% c("03", "04", "05", "06")], na.rm = TRUE),
first_fall_freeze = min(date[temperature_c < freezing_temp & format(date, "%m") %in% c("09", "10", "11", "12")], na.rm = TRUE)
)
# Plot temperature data
ggplot(all_data, aes(x = date, y = temperature_c)) +
geom_line(color = "black") +
geom_hline(yintercept = freezing_temp, color = "blue", linetype = "dashed", size = 0.8) +
labs(x = "Date", y = "Temperature (°C)",
title = "Daily Minimum Temperature with Freeze Dates Highlighted") +
theme_minimal() +
# Highlight each year's last spring freeze and first fall freeze
geom_point(data = freeze_dates, aes(x = last_spring_freeze, y = freezing_temp), color = "green", size = 3) +
geom_point(data = freeze_dates, aes(x = first_fall_freeze, y = freezing_temp), color = "red", size = 3) +
# Annotate each freeze date with the date
geom_text(data = freeze_dates, aes(x = last_spring_freeze, y = freezing_temp + 1,
label = paste("Spring:", last_spring_freeze)), color = "green", hjust = -0.1) +
geom_text(data = freeze_dates, aes(x = first_fall_freeze, y = freezing_temp - 1,
label = paste("Fall:", first_fall_freeze)), color = "red", hjust = -0.1) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggsave("C:/Users/Tanner/OneDrive - Michigan Technological University/PhD/code(r)/figures/temp_data.png", width = 24, height = 8)

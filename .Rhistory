last_spring_freeze_2017 <- temp_data_2017 %>%
filter(temperature_c < freezing_temp, format(date, "%m") %in% c("03", "04", "05", "06")) %>%
summarize(last_spring = max(date, na.rm = TRUE)) %>%
pull(last_spring)

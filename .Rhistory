# ---- Combine all ----
combined_df <- bind_rows(
entrance,
wall_entrance,
wall_back,
ICU_PSY,
ICU_back,
middle_ICU,
control,
psy_entrance
)
start_date <- as.POSIXct("2025-06-01 00:00:00", tz = "America/Detroit")
combined_df %>%
filter(
!source %in% c("Gate Entrance"),
date_time >= start_date,
date_time <= Sys.time()
) %>%
ggplot(aes(x = date_time, y = temp, color = source)) +
geom_line() +
scale_x_datetime(limits = c(start_date, Sys.time())) +
labs(
x = "Date-Time",
y = "Temperature (°C)",
color = "Source"
) +
theme_minimal(base_size = 14) +
theme(
axis.line = element_line(color = "black"),
panel.grid = element_blank()
)

first_fall_freeze_2017 <- temp_data_2017 %>%
filter(temperature_c < freezing_temp, format(date, "%m") %in% c("09", "10", "11", "12")) %>%
summarize(first_fall = min(date, na.rm = TRUE)) %>%
pull(first_fall)

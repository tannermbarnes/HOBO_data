library(dplyr)
library(broom)
# Define date ranges
period1_start <- as.Date("2024-11-01")
period1_end   <- as.Date("2025-04-30")
period2_start <- as.Date("2025-05-01")
period2_end   <- as.Date("2025-09-09")
# Add a period column
combined_data2 <- combined_data %>%
mutate(
date_only = as.Date(date_time),   # ensure a Date column exists
period = case_when(
date_only >= period1_start & date_only <= period1_end ~ "Winter",
date_only >= period2_start & date_only <= period2_end ~ "Summer",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(period))
# Run t-tests by source
t_results <- combined_data2 %>%
group_by(source) %>%
do(tidy(t.test(value ~ period, data = .))) %>%   # 'value' = temperature column
ungroup()
print(t_results)
# Run t-tests by source
t_results <- combined_data2 %>%
group_by(source) %>%
do(tidy(t.test(temp ~ period, data = .))) %>%   # 'temp' = temperature column
ungroup()
print(t_results)
do(tidy(wilcox.test(temp ~ period, data = .)))
do(tidy(wilcox.test(temp ~ period, data = .)))
do(tidy(wilcox.test(temp ~ period, data = combined_data2)))
View(combined_data2)
library(dplyr)
library(ggplot2)
library(lubridate)
library(broom)
# --- 1) Define windows (inclusive) ---
period1_start <- as.Date("2024-11-01")
period1_end   <- as.Date("2025-04-30")
period2_start <- as.Date("2025-05-01")
period2_end   <- as.Date("2025-09-09")
# --- 2) Tag periods and keep only the two windows ---
cd2 <- combined_data %>%
mutate(
date_only = as.Date(date_time, tz = "America/Detroit"),
period = case_when(
date_only >= period1_start & date_only <= period1_end ~ "Winter (Nov–Apr)",
date_only >= period2_start & date_only <= period2_end ~ "Summer (May–Sep 9)",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(period)) %>%
mutate(period = factor(period, levels = c("Winter (Nov–Apr)", "Summer (May–Sep 9)")))
# --- 3) Sanity check: means by source & period ---
summary_means <- cd2 %>%
group_by(source, period) %>%
summarise(n = n(), mean_temp = mean(temp, na.rm = TRUE), .groups = "drop")
print(summary_means, n = Inf)
# --- 4) (Optional) t-tests again, clearly labeled ---
tt <- cd2 %>%
group_by(source) %>%
do(tidy(t.test(temp ~ period, data = .))) %>%
ungroup()
print(tt)
# --- 5) Boxplot: Winter vs Summer per logger ---
ggplot(cd2, aes(x = period, y = temp, fill = period)) +
geom_boxplot(outlier.size = 0.7, alpha = 0.8, width = 0.65) +
stat_summary(fun = mean, geom = "point", shape = 21, size = 2.5, stroke = 0.3, fill = "white") +
facet_wrap(~ source, scales = "free_y") +
labs(
x = NULL,
y = "Temperature (°C)",
fill = "Period",
title = "Temperature by Period per Logger"
) +
scale_fill_manual(values = c("Winter (Nov–Apr)" = "#5DADE2",  # blue
"Summer (May–Sep 9)" = "#F5B041")) # orange
+
theme_minimal(base_size = 14) +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
legend.position  = "top",
axis.line        = element_line(color = "black")
)
# --- 5) Boxplot: Winter vs Summer per logger ---
ggplot(cd2, aes(x = period, y = temp, fill = period)) +
geom_boxplot(outlier.size = 0.7, alpha = 0.8, width = 0.65) +
